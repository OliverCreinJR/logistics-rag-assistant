# Скопируйте этот файл в .env и заполните своими значениями.
# .env в репозиторий НЕ коммитится (см. .gitignore).

# Авторизационные данные GigaChat (Authorization Key из личного кабинета).
# Получить: https://developers.sber.ru/portal/products/gigachat-api
# Это base64-строка, начинается с "OWE2Mz..." или похоже.
GIGACHAT_CREDENTIALS=
